{
  "name": "@illuma/core",
  "description": "A lightweight, type-safe dependency injection container for anything, inspired by Angular's DI system",
  "author": "bebrasmell",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/git-illuma/core"
  },
  "version": "2.1.1",
  "license": "MIT",
  "publish": {
    "include": [
      "src/**/*",
      "README.md"
    ],
    "exclude": [
      "docs/**/*",
      ".vscode/**/*",
      ".github/**/*",
      "artifacts/**/*",
      "node_modules/**/*",
      "dist/**/*",
      ".editorconfig",
      ".gitignore",
      ".swcrc",
      "tsconfig.json",
      "biome.json",
      "CHANGELOG.md",
      "CONTRIBUTING.md",
      "vitest.config.ts",
      "**/*.test.ts",
      "**/*.spec.ts"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./testkit": "./src/testkit.ts",
    "./plugins": "./src/plugins.ts"
  }
}
